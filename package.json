{
  "name": "pw-e2e-automationexercise",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "archive:reports": "tsx scripts/archive-playwright-reports.ts",
    "check:report-tools": "tsx scripts/check-report-tools.ts",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "parse:failures": "tsx scripts/playwright-failure-parser.ts artifacts/history",
    "parse:failures:dir": "tsx scripts/playwright-failure-parser.ts",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:smoke:archive": "tsx scripts/run-playwright-and-archive.ts --grep @smoke",
    "test:full": "npx playwright test",
    "test:full:archive": "tsx scripts/run-playwright-and-archive.ts",
    "test:api": "npx playwright test --project=api",
    "test:api:archive": "tsx scripts/run-playwright-and-archive.ts --project=api",
    "test:report": "npx playwright show-report",
    "capture:network": "tsc scripts/capture-network.ts --outDir scripts/.generated --module commonjs --target es2020 --types node && node scripts/.generated/capture-network.js",
    "spike:ads": "tsx scripts/ad-traffic-spike.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "fast-xml-parser": "^5.3.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  }
}
